# Cloudflare Account ID (required for all operations)
CLOUDFLARE_ACCOUNT_ID=your_account_id_here

# R2 Storage Configuration (required for upload_to_r2.py and preview_cleanup.py)
R2_ACCESS_KEY_ID=your_r2_access_key_here
R2_SECRET_ACCESS_KEY=your_r2_secret_key_here
R2_BUCKET_NAME=npe2api

# Cloudflare API Token (only required for wrangler/worker operations)
# Use "Edit Cloudflare Workers" template or custom with Workers Scripts: Edit + Delete
CLOUDFLARE_API_TOKEN=your_api_token_here

# Optional: GitHub API tokens for reindex script
GH_API_TOKEN=your_github_token_here
CODECOV_API_TOKEN=your_codecov_token_here
